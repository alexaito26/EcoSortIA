# =====================================================================
# EcoSort AI - Variables de entorno (PLANTILLA - SIN VALORES REALES)
# Copia este archivo a .env.local (apps/web) o .env segun corresponda.
# NUNCA subas secretos reales al repositorio.
# =====================================================================

# ---------------------------------------------------------------------
# PUBLICAS - se envian al navegador (prefijo NEXT_PUBLIC_). Fase 2.
# Seguras para el cliente: URL del proyecto y clave publishable/anon.
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Clave publishable (preferida) o anon legacy. Segura para el navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL publica del sitio (usada en callbacks de auth). En dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------
# PRIVADAS - SOLO servidor / CI. NUNCA con prefijo NEXT_PUBLIC_.
# NUNCA usar service_role en codigo cliente.
# ---------------------------------------------------------------------
# Clave service_role (scripts/admin server-side). Fase 4.
SUPABASE_SERVICE_ROLE_KEY=
# CLI y migraciones versionadas. Fase 2.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
# Secreto para validar el token del dispositivo ESP32 (Edge Functions). Fase 4.
DEVICE_INGEST_SECRET=

# ---------------------------------------------------------------------
# WEB PUSH / VAPID - Notificaciones Push. Fase 5.
# La clave privada VAPID vive SOLO en el servidor.
# ---------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ---------------------------------------------------------------------
# SIMULADOR DE DISPOSITIVO (scripts/device-simulator). Fase 4.
# Base de Edge Functions, p. ej. https://<ref>.supabase.co/functions/v1
# ---------------------------------------------------------------------
ECOSORT_API_BASE_URL=
ECOSORT_DEVICE_CODE=ECOSORT-01
# Token generado por scripts/device-token (se muestra una sola vez). NUNCA en Git.
ECOSORT_DEVICE_TOKEN=
# Clave publishable/anon (algunos gateways la exigen como apikey aunque
# verify_jwt este desactivado). Segura para el dispositivo.
ECOSORT_ANON_KEY=
# Compatibilidad (nombres antiguos, opcionales):
SIMULATOR_SUPABASE_URL=
SIMULATOR_DEVICE_TOKEN=

# ---------------------------------------------------------------------
# GENERADOR DE TOKEN (scripts/device-token). SOLO servidor. Fase 4.
# Requiere service_role para llamar a rotate_device_token.
# ---------------------------------------------------------------------
# SUPABASE_URL=            (ver seccion privada arriba)
# SUPABASE_SERVICE_ROLE_KEY= (ver seccion privada arriba)
