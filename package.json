{
  "name": "ecosort-ai",
  "version": "0.1.0",
  "private": true,
  "description": "EcoSort AI - Monorepo Full-Stack + IoT para clasificacion inteligente de residuos",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "simulator:event": "pnpm --filter @ecosort/device-simulator exec tsx src/cli.ts event",
    "simulator:heartbeat": "pnpm --filter @ecosort/device-simulator exec tsx src/cli.ts heartbeat",
    "simulator:stream": "pnpm --filter @ecosort/device-simulator exec tsx src/cli.ts stream",
    "simulator:error": "pnpm --filter @ecosort/device-simulator exec tsx src/cli.ts error",
    "simulator:duplicate": "pnpm --filter @ecosort/device-simulator exec tsx src/cli.ts duplicate",
    "token:generate": "pnpm --filter @ecosort/device-token exec tsx src/index.ts"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
